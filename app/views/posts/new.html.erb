<h1>New Post</h1>

<%= turbo_frame_tag "new_post" do %>
  <%= form_with model: @post do |form| %>
    <div>
      <%= form.label :title %>
      <%= form.text_field :title %>
      <% @post.errors.full_messages_for(:title).each do |message| %>
        <div>
          <%= message %>
        </div>
      <% end %>
    </div>

    <div>
      <%= form.label :body %>
      <%= form.text_area :body %>
      <% @post.errors.full_messages_for(:body).each do |message| %>
        <div>
          <%= message %>
        </div>
      <% end %>
    </div>

    <div>
      <%= form.submit %>
    </div>
  <% end %>
<% end %>